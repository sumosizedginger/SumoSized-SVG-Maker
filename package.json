{
	"name": "svg",
	"private": false,
	"version": "1.1.0",
	"description": "The first agentic Picasso of SVG generation engines. Procedural, physics-simulated, and professional-grade.",
	"keywords": [
		"svg",
		"generative-art",
		"agentic-ai",
		"svelte5",
		"photoshop-killer",
		"procedural-graphics",
		"animation-engine"
	],
	"homepage": "https://github.com/sumosizedginger/SumoSized-SVG-Maker#readme",
	"bugs": {
		"url": "https://github.com/sumosizedginger/SumoSized-SVG-Maker/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sumosizedginger/SumoSized-SVG-Maker.git"
	},
	"license": "MIT",
	"author": "SumoSized Ginger & Antigravity AI",
	"type": "module",
	"main": "./src/lib/engine/index.ts",
	"types": "./src/lib/engine/index.ts",
	"exports": {
		".": {
			"types": "./src/lib/engine/index.ts",
			"import": "./src/lib/engine/index.ts",
			"default": "./src/lib/engine/index.ts"
		}
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"release": "npm run check && vitest run --coverage && npm run build"
	},
	"lint-staged": {
		"*.{ts,js,svelte,json,md,css}": "prettier --write"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/lz-string": "^1.5.0",
		"@vitest/coverage-istanbul": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.3.2",
		"prettier": "^3.8.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@ffmpeg/ffmpeg": "^0.12.15",
		"@ffmpeg/util": "^0.12.2",
		"@types/jszip": "^3.4.0",
		"jszip": "^3.10.1",
		"lz-string": "^1.5.0",
		"mediabunny": "^1.38.0",
		"zod": "^4.3.6"
	}
}
