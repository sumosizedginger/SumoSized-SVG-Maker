exports[`Dynamic Engine Core Tests > Generator [anim-morph] > renders deterministic SVG with default params 1`] = `
"<svg width="100%" height="100%" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
				<title>Vector Morphing</title>
				<path d="M 30,30 L 70,30 L 70,70 L 30,70 Z" fill="#3b82f6" opacity="0.8">
					<animate attributeName="d" values="M 30,30 L 70,30 L 70,70 L 30,70 Z; M 50,20 L 80,80 L 20,80 L 50,20 Z; M 50,10 L 90,50 L 50,90 L 10,50 Z; M 30,30 L 70,30 L 70,70 L 30,70 Z" dur="2.50s" repeatCount="indefinite" />
				</path>
			</svg>"
`;

exports[`Dynamic Engine Core Tests > Generator [anim-neon-flicker] > renders deterministic SVG with default params 1`] = `
"<svg width="100%" height="100%" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
				<title>Neon Flicker</title>
				<rect width="100" height="100" fill="#050510" />
				<defs>
					<filter id="neonBlur-12345" x="-50%" y="-50%" width="200%" height="200%">
						<feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur" />
						<feMerge>
							<feMergeNode in="blur" />
							<feMergeNode in="SourceGraphic" />
						</feMerge>
					</filter>
				</defs>
				<g filter="url(#neonBlur-12345)">
					<animate 
						attributeName="opacity" 
						values="1; 0.60; 1; 0.9; 0.60; 1" 
						keyTimes="0; 0.1; 0.2; 0.6; 0.7; 1" 
						dur="0.20s" 
						repeatCount="indefinite" 
						calcMode="discrete" 
					/>
					<rect x="25" y="45" width="50" height="10" rx="2" fill="none" stroke="#ff00ff" stroke-width="1.5" />
					<text x="50" y="52" font-family="Arial" font-size="6" fill="#ff00ff" text-anchor="middle" font-weight="bold">NEON_LIVE</text>
				</g>
			</svg>"
`;

