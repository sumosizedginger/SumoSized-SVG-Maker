exports[`Dynamic Engine Core Tests > Generator [anim-orbit] > renders deterministic SVG with default params 1`] = `
"<svg width="100%" height="100%" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
        <title>Orbital Loop</title>
        <desc>An animation showing 3 celestial orbits over a 3s duration.</desc>
        <defs>
          <clipPath id="orbitClip-12345"><rect width="100" height="100" /></clipPath>
        </defs>
        <g clip-path="url(#orbitClip-12345)">
          <circle cx="50" cy="50" r="14.666666666666666" fill="none" stroke="#00bbf9" stroke-width="0.50" stroke-dasharray="2 4" opacity="1.00" />
        <g>
          <animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="1.50s" repeatCount="indefinite" />
          <circle cx="50" cy="35.33" r="2.00" fill="#00bbf9" />
        </g>
        <circle cx="50" cy="50" r="29.333333333333332" fill="none" stroke="#00bbf9" stroke-width="0.50" stroke-dasharray="2 4" opacity="0.80" />
        <g>
          <animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="2.70s" repeatCount="indefinite" />
          <circle cx="50" cy="20.67" r="2.00" fill="#00bbf9" />
        </g>
        <circle cx="50" cy="50" r="44" fill="none" stroke="#00bbf9" stroke-width="0.50" stroke-dasharray="2 4" opacity="0.60" />
        <g>
          <animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="3.90s" repeatCount="indefinite" />
          <circle cx="50" cy="6.00" r="2.00" fill="#00bbf9" />
        </g>
        </g>
      </svg>"
`;

exports[`Dynamic Engine Core Tests > Generator [anim-parallax] > renders deterministic SVG with default params 1`] = `
"<svg width="100%" height="100%" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
				<title>Parallax Drift</title>
				<g transform-origin="50 50">
					<animateTransform 
						attributeName="transform" 
						type="translate" 
						values="-10, 0; 0, -10; 10, 0; 0, 10; -10, 0" 
						dur="10.00s" 
						repeatCount="indefinite" 
					/>
					<circle cx="50" cy="50" r="10" fill="gray" opacity="0.5" />
					<rect x="20" y="20" width="60" height="60" fill="none" stroke="gray" stroke-width="0.5" stroke-dasharray="2 2" />
				</g>
			</svg>"
`;

