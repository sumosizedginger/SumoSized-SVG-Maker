exports[`Dynamic Engine Core Tests > Generator [anim-matrix-rain] > renders deterministic SVG with default params 1`] = `
"<svg width="100%" height="100%" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
				<title>Matrix Rain</title>
				<defs>
					<linearGradient id="matrixGradient-12345" x1="0" y1="0" x2="0" y2="1">
