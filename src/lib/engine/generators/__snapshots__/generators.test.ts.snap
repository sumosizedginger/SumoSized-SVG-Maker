`;

exports[`Dynamic Engine Core Tests > Generator [quantum-core] > renders deterministic SVG with default params 1`] = `
"<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="background-color: #020205;">
<title>Quantum Core</title>
<desc>A complex mathematical spirograph with 6-fold symmetry and neon glow effects. Optimized for 100:100 viewport.</desc>

            <defs>
                <clipPath id="quantum-bounds-12345">
                    <rect x="0" y="0" width="100" height="100" />
                </clipPath>
                
                <!-- Hyper-Glow Filter -->
                <filter id="neon-glow-12345" x="-100%" y="-100%" width="300%" height="300%">
                    <!-- Core high-intensity burn -->
                    <feGaussianBlur in="SourceGraphic" stdDeviation="1.2" result="core_blur" />
                    <!-- Mid glow -->
                    <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="mid_blur" />
                    <!-- Ambient outer aura -->
                    <feGaussianBlur in="SourceGraphic" stdDeviation="8" result="outer_blur" />
                    
                    <!-- Color boosting matrix to blow out the highlights like real neon -->
                    <feColorMatrix type="matrix" in="core_blur" result="boosted_core"
                        values="1.5 0 0 0 0  
                                0 1.5 0 0 0  
                                0 0 1.5 0 0  
                                0 0 0 2 0" />

                    <!-- Merge all glow levels + crisp white-hot core -->
                    <feMerge>
                        <feMergeNode in="outer_blur" />
                        <feMergeNode in="mid_blur" />
                        <feMergeNode in="boosted_core" />
                        <feMergeNode in="SourceGraphic" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
        </defs>
<g clip-path="url(#quantum-bounds-12345)">
<defs>
