// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Generators > Quantum Core generates deterministic SVG 1`] = `
"<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="background-color: #0a0005;">
<title>Quantum Core</title>
<desc>A complex mathematical spirograph with 6-fold symmetry and neon glow effects.</desc>

            <defs>
                <clipPath id="quantum-bounds-424242">
                    <rect x="0" y="0" width="100" height="100" />
                </clipPath>
                
                <!-- Hyper-Glow Filter -->
                <filter id="neon-glow-424242" x="-100%" y="-100%" width="300%" height="300%">
                    <!-- Core high-intensity burn -->
                    <feGaussianBlur in="SourceGraphic" stdDeviation="1.2" result="core_blur" />
                    <!-- Mid glow -->
                    <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="mid_blur" />
                    <!-- Ambient outer aura -->
                    <feGaussianBlur in="SourceGraphic" stdDeviation="8" result="outer_blur" />
                    
                    <!-- Color boosting matrix to blow out the highlights like real neon -->
                    <feColorMatrix type="matrix" in="core_blur" result="boosted_core"
                        values="1.5 0 0 0 0  
                                0 1.5 0 0 0  
                                0 0 1.5 0 0  
                                0 0 0 2 0" />

                    <!-- Merge all glow levels + crisp white-hot core -->
                    <feMerge>
                        <feMergeNode in="outer_blur" />
                        <feMergeNode in="mid_blur" />
                        <feMergeNode in="boosted_core" />
                        <feMergeNode in="SourceGraphic" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
        
            < !--Quantum Glitch Filter(Turbulence + Displacement)-- >
                <filter id="quantum-glitch-424242" x = "-50%" y = "-50%" width = "200%" height = "200%" >
                    <feTurbulence type="fractalNoise" baseFrequency = "0.05" numOctaves = "2" result = "noise" seed = "424242" />
                        <feDisplacementMap in="SourceGraphic" in2 = "noise" scale = "15" xChannelSelector = "R" yChannelSelector = "G" />
                            </filter>
                                
